# .env.template - copy to .env and fill values for local development
# Database
DATABASE_DEV_URL=db:5432/alfri
DATABASE_DEV_USER=alfri
DATABASE_DEV_PASSWORD=changeme
DATABASE_PROD_URL=jdbc:postgresql://db:5432/alfri
DATABASE_PROD_USER=alfri
DATABASE_PROD_PASSWORD=changeme

# Shared API key for testing
X_API_KEY=changeme

# Frontend allowed origin for CORS

# Optional: override PYTHON service url for non-docker testing
PYTHON_SERVICE_URL=http://python-service:5000

# Local Keycloak
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/alfri
KEYCLOAK_JWK_SET_URI=http://localhost:8180/realms/alfri/protocol/openid-connect/certs
KEYCLOAK_EVENT_WEBHOOK_SECRET=changeme
KEYCLOAK_EVENT_WEBHOOK_URL=http://172.17.0.1:8080/api/internal/keycloak/users
