            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "alfri-backend",
              "location": "[parameters('location')]",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', parameters('backendIdentityId'))]": {}
                }
              },
              "properties": {
                "managedEnvironmentId": "[parameters('containerAppsEnvironmentId')]",
                "configuration": {
                  "ingress": {
                    "external": false,
                    "targetPort": 8080,
                    "transport": "auto"
                  },
                  "registries": [
                    {
                      "server": "[variables('registryServer')]",
                      "identity": "[parameters('backendIdentityId')]"
                    }
                  ],
                  "secrets": [
                    {
                      "name": "pg-password",
                      "keyVaultUrl": "[format('{0}secrets/pg-password', parameters('keyVaultUri'))]",
                      "identity": "[parameters('backendIdentityId')]"
                    },
                    {
                      "name": "keycloak-admin-password",
                      "keyVaultUrl": "[format('{0}secrets/keycloak-admin-password', parameters('keyVaultUri'))]",
                      "identity": "[parameters('backendIdentityId')]"
                    },
                    {
                      "name": "keycloak-webhook-secret",
                      "keyVaultUrl": "[format('{0}secrets/keycloak-webhook-secret', parameters('keyVaultUri'))]",
                      "identity": "[parameters('backendIdentityId')]"
                    },
                    {
                      "name": "ml-api-key",
                      "keyVaultUrl": "[format('{0}secrets/ml-api-key', parameters('keyVaultUri'))]",
                      "identity": "[parameters('backendIdentityId')]"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "alfri-backend",
                      "image": "[parameters('backendImageName')]",
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1Gi"
                      },
                      "env": [
                        {
                          "name": "SPRING_PROFILES_ACTIVE",
                          "value": "azure-dev"
                        },
                        {
                          "name": "AZURE_PG_HOST",
                          "value": "[parameters('pgHost')]"
                        },
                        {
                          "name": "AZURE_PG_DATABASE",
                          "value": "[parameters('pgDatabase')]"
                        },
                        {
                          "name": "AZURE_PG_USER",
                          "value": "[parameters('pgAdminUser')]"
                        },
                        {
                          "name": "AZURE_PG_PASSWORD",
                          "secretRef": "pg-password"
                        },
                        {
                          "name": "KEYCLOAK_ISSUER_URI",
                          "value": "[format('https://{0}/realms/{1}', parameters('keycloakFqdn'), parameters('keycloakRealm'))]"
                        },
                        {
                          "name": "KEYCLOAK_JWK_SET_URI",
                          "value": "[format('https://{0}/realms/{1}/protocol/openid-connect/certs', parameters('keycloakFqdn'), parameters('keycloakRealm'))]"
                        },
                        {
                          "name": "KEYCLOAK_INTERNAL_ISSUER_URI",
                          "value": "[format('http://alfri-keycloak/realms/{0}', parameters('keycloakRealm'))]"
                        },
                        {
                          "name": "KEYCLOAK_REALM",
                          "value": "[parameters('keycloakRealm')]"
                        },
                        {
                          "name": "KEYCLOAK_CLIENT_ID",
                          "value": "alfri-frontend"
                        },
                        {
                          "name": "KEYCLOAK_ADMIN_REALM",
                          "value": "master"
                        },
                        {
                          "name": "KEYCLOAK_ADMIN_CLIENT_ID",
                          "value": "admin-cli"
                        },
                        {
                          "name": "KEYCLOAK_ADMIN_USERNAME",
                          "value": "[parameters('keycloakAdminUser')]"
                        },
                        {
                          "name": "KEYCLOAK_ADMIN_PASSWORD",
                          "secretRef": "keycloak-admin-password"
                        },
                        {
                          "name": "KEYCLOAK_EVENT_WEBHOOK_SECRET",
                          "secretRef": "keycloak-webhook-secret"
                        },
                        {
                          "name": "PYTHON_SERVICE_BASE_URL",
                          "value": "http://alfri-ml-service"
                        },
                        {
                          "name": "PYTHON_SERVICE_API_KEY",
                          "secretRef": "ml-api-key"
                        },
                        {
                          "name": "CORS_ALLOWED_ORIGINS",
                          "value": "[format('https://{0}', parameters('frontendFqdn'))]"
                        }
                      ],
                      "probes": [
                        {
                          "type": "Startup",
                          "httpGet": {
                            "path": "/actuator/health/readiness",
                            "port": 8080,
                            "scheme": "HTTP"
                          },
                          "initialDelaySeconds": 30,
                          "periodSeconds": 10,
                          "failureThreshold": 12
                        },
                        {
                          "type": "Readiness",
                          "httpGet": {
                            "path": "/actuator/health/readiness",
                            "port": 8080,
                            "scheme": "HTTP"
                          },
                          "periodSeconds": 10,
                          "failureThreshold": 3
                        },
                        {
                          "type": "Liveness",
                          "httpGet": {
                            "path": "/actuator/health/liveness",
                            "port": 8080,
                            "scheme": "HTTP"
                          },
                          "periodSeconds": 30,
                          "failureThreshold": 3
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 0,
                    "maxReplicas": 1
                  }
                }
              }
            },
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "alfri-ml-service",
              "location": "[parameters('location')]",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', parameters('mlIdentityId'))]": {}
                }
              },
              "properties": {
                "managedEnvironmentId": "[parameters('containerAppsEnvironmentId')]",
                "configuration": {
                  "ingress": {
                    "external": false,
                    "targetPort": 5000,
                    "transport": "auto"
                  },
                  "registries": [
                    {
                      "server": "[variables('registryServer')]",
                      "identity": "[parameters('mlIdentityId')]"
                    }
                  ],
                  "secrets": [
                    {
                      "name": "pg-password",
                      "keyVaultUrl": "[format('{0}secrets/pg-password', parameters('keyVaultUri'))]",
                      "identity": "[parameters('mlIdentityId')]"
                    },
                    {
                      "name": "ml-api-key",
                      "keyVaultUrl": "[format('{0}secrets/ml-api-key', parameters('keyVaultUri'))]",
                      "identity": "[parameters('mlIdentityId')]"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "alfri-ml-service",
                      "image": "[parameters('mlImageName')]",
                      "resources": {
                        "cpu": "[json('1')]",
                        "memory": "2Gi"
                      },
                      "env": [
                        {
                          "name": "MODE",
                          "value": "prod"
                        },
                        {
                          "name": "DATABASE_HOST",
                          "value": "[format('{0}:5432/{1}', parameters('pgHost'), parameters('pgDatabase'))]"
                        },
                        {
                          "name": "DATABASE_USER",
                          "value": "[parameters('pgAdminUser')]"
                        },
                        {
                          "name": "DATABASE_PASSWORD",
                          "secretRef": "pg-password"
                        },
                        {
                          "name": "DATABASE_SSLMODE",
                          "value": "require"
                        },
                        {
                          "name": "API_KEYS",
                          "secretRef": "ml-api-key"
                        }
                      ],
                      "probes": [
                        {
                          "type": "Startup",
                          "httpGet": {
                            "path": "/health/ready",
                            "port": 5000,
                            "scheme": "HTTP"
                          },
                          "initialDelaySeconds": 30,
                          "periodSeconds": 10,
                          "failureThreshold": 12
                        },
                        {
                          "type": "Readiness",
                          "httpGet": {
                            "path": "/health/ready",
                            "port": 5000,
                            "scheme": "HTTP"
                          },
                          "periodSeconds": 15,
                          "failureThreshold": 3
                        },
                        {
                          "type": "Liveness",
                          "httpGet": {
                            "path": "/health/live",
                            "port": 5000,
                            "scheme": "HTTP"
                          },
                          "periodSeconds": 30,
                          "failureThreshold": 3
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 0,
                    "maxReplicas": 1
                  }
                }
              }
            },
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "alfri-keycloak",
              "location": "[parameters('location')]",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', parameters('keycloakIdentityId'))]": {}
                }
              },
              "properties": {
                "managedEnvironmentId": "[parameters('containerAppsEnvironmentId')]",
                "configuration": {
                  "ingress": {
                    "external": true,
                    "targetPort": 8080,
                    "transport": "auto"
                  },
                  "registries": [
                    {
                      "server": "[variables('registryServer')]",
                      "identity": "[parameters('keycloakIdentityId')]"
                    }
                  ],
                  "secrets": [
                    {
                      "name": "kc-db-password",
                      "keyVaultUrl": "[format('{0}secrets/keycloak-db-password', parameters('keyVaultUri'))]",
                      "identity": "[parameters('keycloakIdentityId')]"
                    },
                    {
                      "name": "keycloak-admin-password",
                      "keyVaultUrl": "[format('{0}secrets/keycloak-admin-password', parameters('keyVaultUri'))]",
                      "identity": "[parameters('keycloakIdentityId')]"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "alfri-keycloak",
                      "image": "[parameters('keycloakImageName')]",
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1Gi"
                      },
                      "args": [
                        "start",
                        "--import-realm"
                      ],
                      "env": [
                        {
                          "name": "KC_DB",
                          "value": "postgres"
                        },
                        {
                          "name": "KC_DB_URL",
                          "value": "[format('jdbc:postgresql://{0}:5432/keycloak?sslmode=require', parameters('pgHost'))]"
                        },
                        {
                          "name": "KC_DB_USERNAME",
                          "value": "keycloak"
                        },
                        {
                          "name": "KC_DB_PASSWORD",
                          "secretRef": "kc-db-password"
                        },
                        {
                          "name": "KC_HOSTNAME",
                          "value": "[parameters('keycloakFqdn')]"
                        },
                        {
                          "name": "KC_HOSTNAME_STRICT",
                          "value": "false"
                        },
                        {
                          "name": "KC_PROXY",
                          "value": "edge"
                        },
                        {
                          "name": "KC_HTTP_ENABLED",
                          "value": "true"
                        },
                        {
                          "name": "KEYCLOAK_ADMIN",
                          "value": "[parameters('keycloakAdminUser')]"
                        },
                        {
                          "name": "KEYCLOAK_ADMIN_PASSWORD",
                          "secretRef": "keycloak-admin-password"
                        },
                        {
                          "name": "KC_HEALTH_ENABLED",
                          "value": "true"
                        },
                        {
                          "name": "KC_METRICS_ENABLED",
                          "value": "true"
                        }
                      ],
                      "probes": [
                        {
                          "type": "Startup",
                          "httpGet": {
                            "path": "/health/ready",
                            "port": 8080,
                            "scheme": "HTTP"
                          },
                          "initialDelaySeconds": 60,
                          "periodSeconds": 10,
                          "failureThreshold": 18
                        },
                        {
                          "type": "Readiness",
                          "httpGet": {
                            "path": "/health/ready",
                            "port": 8080,
                            "scheme": "HTTP"
                          },
                          "periodSeconds": 15,
                          "failureThreshold": 3
                        },
                        {
                          "type": "Liveness",
                          "httpGet": {
                            "path": "/health/live",
                            "port": 8080,
                            "scheme": "HTTP"
                          },
                          "periodSeconds": 30,
                          "failureThreshold": 3
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 0,
                    "maxReplicas": 1
                  }
                }
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'deploy-identities')]",
        "[resourceId('Microsoft.Resources/deployments', 'deploy-keyvault')]",
        "[resourceId('Microsoft.Resources/deployments', 'deploy-roles')]"
      ]
    }
  ],
  "outputs": {
    "AZURE_CONTAINER_REGISTRY_ENDPOINT": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-07-01').loginServer]"
    },
    "AZURE_KEY_VAULT_ENDPOINT": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-keyvault'), '2025-04-01').outputs.keyVaultUri.value]"
    },
    "AZURE_KEY_VAULT_NAME": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-keyvault'), '2025-04-01').outputs.keyVaultName.value]"
    },
    "SERVICE_FRONTEND_NAME": {
      "type": "string",
      "value": "alfri-frontend"
    },
    "SERVICE_BACKEND_NAME": {
      "type": "string",
      "value": "alfri-backend"
    },
    "SERVICE_ML_SERVICE_NAME": {
      "type": "string",
      "value": "alfri-ml-service"
    },
    "SERVICE_KEYCLOAK_NAME": {
      "type": "string",
      "value": "alfri-keycloak"
    },
    "FRONTEND_FQDN": {
      "type": "string",
      "value": "[format('alfri-frontend.{0}', reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName')), '2024-03-01').defaultDomain)]"
    },
    "KEYCLOAK_FQDN": {
      "type": "string",
      "value": "[format('alfri-keycloak.{0}', reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName')), '2024-03-01').defaultDomain)]"
    },
    "POSTGRES_HOST": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('postgresServerName')), '2023-06-01-preview').fullyQualifiedDomainName]"
    }
  }
}